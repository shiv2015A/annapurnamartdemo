rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, < 100 chars)
    //   - description: string (optional, < 1000 chars)
    //   - price: number (required, >= 0)
    //   - imageUrl: string (optional, valid URL)
    //   - category: string (required, < 50 chars)
    //   - stock: number (required, >= 0)
    //   - createdAt: timestamp (immutable)
    //
    // Collection: users
    // Document ID: user uid
    // Fields:
    //   - email: string (required)
    //   - name: string (optional)
    //   - role: string (required, 'admin' or 'customer')
    //   - createdAt: timestamp (immutable)
    //
    // Collection: orders
    // Document ID: auto-generated
    // Fields:
    //   - orderId: string (required)
    //   - items: list (required)
    //   - totalPrice: number (required)
    //   - phone: string (required)
    //   - address: string (required)
    //   - gps: string (optional)
    //   - status: string (required)
    //   - createdAt: timestamp (immutable)
    //   - userId: string (optional)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "shivanshdubey013@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^data:image/.*")) && url.size() < 1048576;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProduct(data) {
      let allowedFields = ['name', 'description', 'price', 'imageUrl', 'category', 'stock', 'createdAt'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['name', 'price', 'category', 'stock']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             data.price is number && data.price >= 0 &&
             (!('imageUrl' in data) || isValidUrl(data.imageUrl)) &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidUser(data) {
      let allowedFields = ['email', 'name', 'role', 'createdAt', 'phone', 'address', 'gps'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['email', 'role']) &&
             data.email is string && data.email.size() < 200 &&
             (!('name' in data) || (data.name is string && data.name.size() < 200)) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() < 50)) &&
             (!('address' in data) || (data.address is string && data.address.size() < 1000)) &&
             (!('gps' in data) || (data.gps is string && data.gps.size() < 200)) &&
             data.role in ['admin', 'customer'];
    }

    function isValidOrder(data) {
      let allowedFields = ['orderId', 'items', 'totalPrice', 'phone', 'address', 'gps', 'status', 'createdAt', 'userId'];
      return hasOnlyAllowedFields(allowedFields) &&
             hasRequiredFields(['orderId', 'items', 'totalPrice', 'phone', 'address', 'status']) &&
             data.orderId is string && data.orderId.size() > 0 && data.orderId.size() < 50 &&
             data.items is list && data.items.size() > 0 && data.items.size() < 100 &&
             data.totalPrice is number && data.totalPrice >= 0 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 20 &&
             data.address is string && data.address.size() > 0 && data.address.size() < 500 &&
             (!('gps' in data) || (data.gps is string && data.gps.size() < 100)) &&
             (!('userId' in data) || (data.userId is string && data.userId.size() < 100)) &&
             data.status in ['Pending', 'Processing', 'Shipped', 'Delivered', 'Cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if true; // Anyone can read products
      allow create: if isAdmin() && isValidProduct(request.resource.data) && request.resource.data.createdAt == request.time;
      allow update: if isAdmin() && isValidProduct(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.createdAt == request.time &&
                    (request.resource.data.role == 'customer' || isAdmin()); // Only admin can create admin
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    (!('createdAt' in resource.data) || ('createdAt' in request.resource.data && request.resource.data.createdAt == resource.data.createdAt)) &&
                    (!('role' in resource.data) || request.resource.data.role == resource.data.role || isAdmin()); // Only admin can change role
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid); // Admin can read all, users can read their own
      allow create: if isValidOrder(request.resource.data) && request.resource.data.createdAt == request.time && (!('userId' in request.resource.data) || (isAuthenticated() && request.resource.data.userId == request.auth.uid));
      allow update: if isAdmin() && isValidOrder(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }
  }
}
